# Contoh environment variables untuk Vercel atau testing lokal.
# Pilih salah satu gaya koneksi: DATABASE_URL atau DB_*.

# Opsi 1: connection string dari provider MySQL cloud.
DATABASE_URL=mysql://user:password@host:3306/warehouse_inventory?ssl-mode=REQUIRED

# Opsi 2: env terpisah.
DB_HOST=host_mysql_anda
DB_PORT=3306
DB_NAME=warehouse_inventory
DB_USER=user_database
DB_PASS=password_database
DB_CHARSET=utf8mb4
DB_SSL_MODE=REQUIRED
DB_AUTO_INSTALL=true

# Jika provider memberi file/path CA khusus, isi ini.
# DB_SSL_CA=/path/to/ca.pem
